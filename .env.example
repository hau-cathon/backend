# Flask Configuration
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
HOST=0.0.0.0
PORT=5000

# MongoDB
MONGODB_SETTINGS=mongodb://localhost:27017/helpdesk_db

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# CORS
# Opcje:
# - local: localhost + 127.0.0.1 + lokalne IP (10.x, 172.16-31.x, 192.168.x) na dowolnym porcie
# - *: wszystkie originy (uzywaj tylko tymczasowo)
# - lista po przecinku: np. http://localhost:8081,http://127.0.0.1:19006
CORS_ORIGINS=local

# Whisper Model Size (tiny, base, small, medium, large)
# tiny/base - szybkie (dobre do demo)
# small/medium - wolniejsze, bardziej dokładne
# large - najwolniejsze, najbardziej dokładne
WHISPER_MODEL_SIZE=base

# Email (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Email (IMAP - odczyt)
IMAP_SERVER=imap.gmail.com
